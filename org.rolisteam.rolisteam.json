{
    "id": "org.rolisteam.rolisteam",
    "base": "io.qt.qtwebengine.BaseApp",
    "base-version": "6.10",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "rolisteam",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network",
        "--socket=pulseaudio",
        "--filesystem=xdg-documents",
        "--env=TMPDIR=/var/tmp",
        "--env=GST_PLUGIN_PATH=/usr/lib/x86_64-linux-gnu/gstreamer-1.0/:/usr/lib/aarch64-linux-gnu/gstreamer-1.0/"
    ],
    "cleanup-commands": [
        "/app/cleanup-BaseApp.sh"
    ],
    "modules": [
        {
            "name": "rolisteam",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE:STRING=Release", 
                "-DBUILD_TESTING:BOOL=OFF"
            ],
            "post-install": [
                "rm -f /app/share/metainfo/org.rolisteam.rolisteam.appdata.xml",
                "install -Dm644 org.rolisteam.rolisteam.metainfo.xml /app/share/metainfo/org.rolisteam.rolisteam.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://invent.kde.org/rolisteam/rolisteam.git",
                    "commit": "7ada7e0dbc298179e89e5b50a4494c33b808e88f"
                },
                {
                    "type": "file",
                    "path": "org.rolisteam.rolisteam.metainfo.xml"
                }
            ]
        }
    ]
}
